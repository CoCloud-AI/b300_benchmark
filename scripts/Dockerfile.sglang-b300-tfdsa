# Dockerfile.sglang-b300-tfdsa — GLM-5.2 enablement on SGLang 0.5.14
#
# Base: sglang-b300:v0.5.14 (= lmsysorg/sglang:v0.5.14-cu130-runtime + distro fix).
# Adds ONE string to transformers' ALLOWED_LAYER_TYPES allowlist:
#   'deepseek_sparse_attention'
# This is a verbatim backport of upstream transformers main, which lists it as:
#   "deepseek_sparse_attention",  # for models with DSA indexer (GLM MoE DSA, DeepSeek V32)
# Without it, transformers 5.8.1 (bundled) rejects nvidia/GLM-5.2-NVFP4 at config
# load (layer_types = deepseek_sparse_attention x78) even though BOTH the config
# class (GlmMoeDsaConfig) and the SGLang model (GlmMoeDsaForCausalLM, glm4_moe.py)
# exist in the image. Verified CPU-side: config loads OK with the patch.
# The patch only extends an allowlist — models that already load are unaffected.
#
# Build: docker build -t sglang-b300:v0.5.14-tfdsa -f Dockerfile.sglang-b300-tfdsa .
FROM sglang-b300:v0.5.14
RUN python3 - <<'PY'
import re, pathlib
p = pathlib.Path('/usr/local/lib/python3.12/dist-packages/transformers/configuration_utils.py')
src = p.read_text()
assert 'deepseek_sparse_attention' not in src, 'already patched'
new = src.replace('ALLOWED_LAYER_TYPES = (', 'ALLOWED_LAYER_TYPES = (\n    "deepseek_sparse_attention",  # backport of upstream main (GLM MoE DSA, DeepSeek V32)', 1)
assert new != src, 'anchor not found'
p.write_text(new)
print('patched ALLOWED_LAYER_TYPES')
PY
